{
  "addr": "127.0.0.1:50071",
  "root_dir": "share",
  "db_path": "runtime/roodox-smoke.db",
  "runtime": {
    "binary_path": "bin/roodox_server.exe",
    "state_dir": "runtime",
    "pid_file": "runtime/roodox_server.pid",
    "log_dir": "runtime/logs",
    "stdout_log_name": "server.stdout.log",
    "stderr_log_name": "server.stderr.log",
    "graceful_stop_timeout_seconds": 10,
    "windows_service": {
      "name": "RoodoxServerSmoke",
      "display_name": "Roodox Server Smoke",
      "description": "Roodox server smoke deployment validation",
      "start_type": "manual"
    }
  },
  "remote_build_enabled": false,
  "auth_enabled": true,
  "shared_secret": "replace-with-smoke-secret",
  "tls_enabled": true,
  "tls_cert_path": "certs/roodox-server-cert.pem",
  "tls_key_path": "certs/roodox-server-key.pem",
  "database": {
    "checkpoint_interval_seconds": 300,
    "checkpoint_mode": "truncate",
    "backup_dir": "runtime/backups",
    "backup_interval_seconds": 86400,
    "backup_keep_latest": 2
  },
  "control_plane": {
    "server_id": "srv-smoke",
    "default_device_group": "smoke",
    "heartbeat_interval_seconds": 15,
    "default_policy_revision": 1,
    "available_actions": [
      "reconnect_overlay",
      "resync"
    ],
    "diagnostics_keep_latest": 2,
    "assigned_config": {
      "mount_path": "",
      "sync_roots": [
        "."
      ],
      "conflict_policy": "manual",
      "read_only": false,
      "auto_connect": true,
      "bandwidth_limit": 0,
      "log_level": "info",
      "large_file_threshold": 67108864
    },
    "join_bundle": {
      "overlay_provider": "",
      "overlay_join_config_json": "{}",
      "service_discovery": {
        "mode": "static",
        "host": "127.0.0.1",
        "port": 50071,
        "use_tls": true,
        "tls_server_name": "localhost"
      }
    }
  },
  "cleanup": {
    "temp_artifacts": {
      "enabled": true,
      "interval_seconds": 300,
      "retention_seconds": 3600,
      "max_bytes": 134217728,
      "prefixes": [
        "roodox-suite-",
        "roodox-stress-"
      ]
    },
    "build_workdirs": {
      "interval_seconds": 300,
      "retention_seconds": 3600,
      "max_bytes": 268435456
    },
    "conflict_files": {
      "enabled": true,
      "interval_seconds": 3600,
      "retention_seconds": 3600,
      "max_bytes": 134217728,
      "max_copies_per_path": 5
    },
    "log_files": {
      "enabled": true,
      "dir": "runtime/logs",
      "patterns": [
        "server*.log"
      ],
      "interval_seconds": 900,
      "retention_seconds": 3600,
      "max_bytes": 134217728
    }
  }
}
